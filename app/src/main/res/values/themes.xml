<resources>
    <!-- Base theme: defers colors to Compose (Material You). -->
    <style name="Theme.MobilParkolas" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- Splash screen: brand-blue background with the transparent logo. -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/ic_launcher_background</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.MobilParkolas</item>
    </style>
</resources>
